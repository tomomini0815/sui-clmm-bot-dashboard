# Sui Wallet Private Key (Starting with suiprivkey...)
PRIVATE_KEY=your_private_key_here

# Sui RPC URL (Use testnet for safety initially)
SUI_RPC_URL=https://fullnode.testnet.sui.io

# Telegram Notifications (Optional, leave blank to disable)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Bot Configurations
# LP Amount in USDC
LP_AMOUNT_USDC=500
# Hedge Ratio (0.5 = 50% short of LP amount)
HEDGE_RATIO=0.5
# Rebalance Range (0.05 = ±5%)
RANGE_WIDTH=0.05
# Checking interval in ms (60000 = 60s)
MONITOR_INTERVAL_MS=60000
# Cooldown period after a rebalance in ms (600000 = 10 minutes)
COOLDOWN_PERIOD_MS=600000
