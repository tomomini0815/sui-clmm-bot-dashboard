# ========================================================
# Sui CLMM Bot System Configuration
# ========================================================

# Suiウォレットの秘密鍵 (!!! 絶対に他人に教えないでください !!!)
# 対応フォーマット: 'suiprivkey...' で始まる文字列、または '0x...' 形式
PRIVATE_KEY=your_private_key_here

# Sui RPC URL (Suiネットワークの接続先: 実際の資金を使う場合はMainnet)
SUI_RPC_URL=https://fullnode.mainnet.sui.io:443

# Telegram通知設定 (オプション: 使わない場合は空欄にしてください)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ========================================================
# 取引・ヘッジのデフォルト設定
# ========================================================

# ボットの初期LP（流動性）運用額 (単位: USDC)
LP_AMOUNT_USDC=50

# ヘッジ率 (0.5 = 変動リスクの50%をBluefinでショートヘッジ)
HEDGE_RATIO=0.5

# リバランス実行の価格変動幅 (0.05 = 現在価格から上下5%変動でリバランス)
RANGE_WIDTH=0.05

# 監視インターバル (ミリ秒: 60000 = 60秒に1回価格をチェック)
MONITOR_INTERVAL_MS=60000

# リバランス後の待機（クールダウン）期間 (ミリ秒: 600000 = 10分)
COOLDOWN_PERIOD_MS=600000
